# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication and sessions (server-only, at least 32 random characters)
ADMIN_SESSION_SECRET=replace-with-long-random-string
USER_SESSION_SECRET=replace-with-long-random-string
PARTNER_SESSION_SECRET=replace-with-long-random-string
CERTIFICATION_QR_SECRET=replace-with-long-random-string
MEMBER_IDENTIFIER_RESERVATION_HMAC_SECRET=replace-with-at-least-32-random-characters
MEMBER_EMAIL_VERIFICATION_HMAC_SECRET=replace-with-at-least-32-random-characters
GRADUATE_VERIFICATION_HMAC_SECRET=replace-with-at-least-32-random-characters

# Admin edge protection. Set these in Production before exposing /admin.
ADMIN_BASIC_AUTH_USERNAME=replace-with-admin-gateway-username
ADMIN_BASIC_AUTH_PASSWORD=replace-with-long-random-password

# Mattermost direct Sender registry (server-only)
# The key must be exactly 32 random bytes encoded as base64.
MM_BASE_URL=https://mattermost.example.com
MM_SENDER_CREDENTIALS_ACTIVE_KEY_VERSION=1
MM_SENDER_CREDENTIALS_KEY_V1=replace-with-32-byte-base64-key
# Sender login IDs and passwords are entered by a Super Admin in /admin/cycle.

# Partner billing and business-status lookup
PARTNER_BILLING_BANK_NAME=은행명
PARTNER_BILLING_BANK_ACCOUNT=000-000000-00-000
PARTNER_BILLING_ACCOUNT_HOLDER=예금주명
NTS_BUSINESS_STATUS_SERVICE_KEY=your-data-go-kr-service-key

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sender@example.com
SMTP_PASS=your-smtp-password
SUGGEST_NOTIFY_EMAIL=operator@example.com

# Web Push and scheduled jobs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:operator@example.com
CRON_SECRET=replace-with-long-random-string

# Public site URL
NEXT_PUBLIC_SITE_URL=https://ssartnership.myknow.xyz
