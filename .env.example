# Admin credentials
ADMIN_ID=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-long-random-string

# Partner portal
PARTNER_SESSION_SECRET=replace-with-long-random-string
# Partner billing bank transfer account shown in the partner portal.
# Do not prefix these with NEXT_PUBLIC_; the server passes the values only to
# authenticated partner plan pages.
PARTNER_BILLING_BANK_NAME=은행명
PARTNER_BILLING_BANK_ACCOUNT=000-000000-00-000
PARTNER_BILLING_ACCOUNT_HOLDER=예금주명
# Optional: 공공데이터포털 국세청 사업자등록 상태조회 서비스키
# NTS_BUSINESS_STATUS_SERVICE_KEY=your-data-go-kr-service-key
# Optional fallback used only when NTS_BUSINESS_STATUS_SERVICE_KEY is empty
# DATA_GO_KR_SERVICE_KEY=your-data-go-kr-service-key
# Optional: restrict admin paths to fixed client IPs
# ADMIN_ALLOWED_IPS=127.0.0.1,203.0.113.10
# Optional: add HTTP Basic Auth in front of /admin and admin APIs
# ADMIN_BASIC_AUTH_USERNAME=admin-gateway
# ADMIN_BASIC_AUTH_PASSWORD=change-me-too

# Supabase
# Supabase project values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Data source
# NEXT_PUBLIC_DATA_SOURCE=mock
# Optional override for partner portal only; otherwise follows NEXT_PUBLIC_DATA_SOURCE
# NEXT_PUBLIC_PARTNER_PORTAL_DATA_SOURCE=mock

# Optional Preview sync credential seed.
# When both values are set in CI secrets, npm run sync:preview restores the
# member row and then re-seeds this Preview-only password. Never point this at
# Production secrets or commit real credentials.
# PREVIEW_TEST_MEMBER_USERNAME=your.mm.username
# PREVIEW_TEST_MEMBER_PASSWORD=StrongPreviewOnly!123

# SMTP (for suggestion notifications and partner portal password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=myknow@ssafy.com
SMTP_PASS=your-smtp-password
# Optional: override the visible sender address when it differs from SMTP_USER
# SMTP_FROM_EMAIL=myknow@ssafy.com
# Optional: only for legacy SMTP servers that fail TLS with "dh key too small"
# SMTP_TLS_MIN_DH_SIZE=512
# SMTP_TLS_CIPHERS=DEFAULT@SECLEVEL=0
# Temporary fallback for existing Naver SMTP deployments:
# NAVER_SMTP_USER=your-naver-id@naver.com
# NAVER_SMTP_PASS=your-naver-smtp-password
SUGGEST_NOTIFY_EMAIL=myknow@ssafy.com

# User session
USER_SESSION_SECRET=replace-with-long-random-string
CERTIFICATION_QR_SECRET=replace-with-long-random-string
# 수료생 이메일 코드·문서번호 HMAC·신청 세션 서명용. 32자 이상이며 절대 NEXT_PUBLIC_로 노출하지 않습니다.
GRADUATE_VERIFICATION_HMAC_SECRET=replace-with-at-least-32-random-characters

# SSAFY Verify
NEXT_PUBLIC_SSAFY_VERIFY_CLIENT_ID=client_example_public
SSAFY_VERIFY_ISSUER=https://verify.myknow.xyz
SSAFY_VERIFY_CLIENT_ID=client_example_public
SSAFY_VERIFY_REDIRECT_URIS=https://ssartnership.myknow.xyz/auth/ssafy,https://ssartnership-git-dev-myknows-projects.vercel.app/auth/ssafy
# Confidential client에서만 설정합니다. 브라우저에 노출하지 마세요.
# SSAFY_VERIFY_CLIENT_SECRET=replace-with-issued-confidential-secret
# Server API 위임용 confidential credential입니다. 브라우저에 노출하지 마세요.
SSAFY_VERIFY_SERVER_CLIENT_ID=server_client_example
SSAFY_VERIFY_SERVER_CLIENT_SECRET=replace-with-issued-server-secret
# Optional: defaults to ${SSAFY_VERIFY_ISSUER}/v1
# SSAFY_VERIFY_SERVER_API_BASE_URL=https://verify.myknow.xyz/v1
# Optional live smoke test. Keep disabled unless you intentionally want to call
# the real SSAFY Verify Server API. Set SEND_MM only when a real DM to @myknow is OK.
# SSAFY_VERIFY_LIVE_SMOKE=0
# SSAFY_VERIFY_SMOKE_USERNAME=myknow
# SSAFY_VERIFY_SMOKE_COHORT=15
# SSAFY_VERIFY_SMOKE_MATTERMOST_USER_ID=optional-asserted-myknow-user-id
# SSAFY_VERIFY_SMOKE_TEMPLATE_ID=ssartnership_admin_notification
# SSAFY_VERIFY_SMOKE_PURPOSE=announcement
# SSAFY_VERIFY_SMOKE_SINGLE_TEMPLATE_ID=ssartnership_manual_member_temp_password
# SSAFY_VERIFY_SMOKE_SINGLE_PURPOSE=manual_member_temp_password
# SSAFY_VERIFY_SMOKE_SEND_MM=0
# SSAFY_VERIFY_SMOKE_URL=https://ssartnership-git-dev-myknows-projects.vercel.app/auth/signup

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:myknow@ssafy.com
CRON_SECRET=replace-with-long-random-string

# Site URL (SEO)
NEXT_PUBLIC_SITE_URL=https://ssartnership.myknow.xyz
