    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^6.1.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "chromatic": "^16.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-storybook": "10.3.5",
    "lighthouse": "^12.6.1",
    "playwright": "^1.59.1",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0",
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.7"
    },
    "minimatch@10.2.4": {
