{
  "name": "ssartnership",
  "version": "1.11.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "check:lockfile": "node scripts/check-lockfile-linux.mjs",
    "check:lockfile:linux": "node scripts/check-lockfile-linux.mjs",
    "build": "next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "test": "node --import ./tests/alias-register.mjs --test tests/*.test.mts tests/push/*.test.mts",
    "test-storybook": "vitest run --project=storybook",
    "test-storybook:watch": "vitest --project=storybook",
    "ci:local": "npm ci && npm run check:lockfile && npm run lint && npm run test && npm run build && npm run build-storybook && npm run test-storybook",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "sync:preview": "node scripts/supabase-sync-preview.mjs",
    "rss:refresh": "node scripts/refresh-rss.mjs",
    "perf:lighthouse": "npm run build && node scripts/lighthouse-check.mjs",
    "test:mm-profile": "node --import ./tests/alias-register.mjs --test tests/mm-profile-csv.test.mts",
    "test:partner-portal": "node --import ./tests/alias-register.mjs --test tests/partner-portal.mock.test.mts",
    "test:ssafy-cycle": "node --import ./tests/alias-register.mjs --test tests/ssafy-cycle-simulation.test.mts",
    "test:ssafy-verify:live": "sh -c 'if [ -f .env ]; then node --env-file=.env --import ./tests/alias-register.mjs --test tests/live/ssafy-verify-live-smoke.test.mts; else node --import ./tests/alias-register.mjs --test tests/live/ssafy-verify-live-smoke.test.mts; fi'",
    "validate:migrations": "node scripts/validate-supabase-migrations.mjs",
    "audit:security": "node scripts/security-audit.mjs",
    "bootstrap:super-admin": "node scripts/bootstrap-super-admin.mjs",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
